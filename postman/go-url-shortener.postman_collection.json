        "description": "Checks service status and version."
      },
      "response": []
    },
    {
      "name": "Encode URL (valid)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"url\": \"https://www.theguardian.com/travel/2026/jun/18/weekend-guide-to-istanbul\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/encode",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "encode"
          ]
        },
        "description": "Creates a short URL from a normal public article link."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"status is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var data = pm.response.json();",
              "if (data.short_code) {",
              "    pm.collectionVariables.set(\"short_code\", data.short_code);",
              "}"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Decode URL (using short_code)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"short_code\": \"{{short_code}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/decode",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "decode"
          ]
        },
        "description": "Looks up the original URL by short code."
      },
      "response": []
    },
    {
      "name": "Encode URL (invalid scheme example)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"url\": \"javascript:alert('hi')\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/encode",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "encode"
          ]
        },
        "description": "Negative test: blocked scheme should return INVALID_URL."
      },
      "response": []
    }
  ],
  "variable": [
